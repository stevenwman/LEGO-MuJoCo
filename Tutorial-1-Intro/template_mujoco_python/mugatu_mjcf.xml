<mujoco>

	<option gravity="0 0 -9.81"/>
	
	<asset>
		<mesh name="r_leg" file = "base_link.STL"/>
		<mesh name="l_leg" file = "Empty_Link.STL"/>
	</asset>

	<worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
		<geom type="plane" size="1 1 0.1" rgba=".9 0 0 1"/>

		<body pos="0 0 1" euler="90 0 0">
			<joint type="free"/>
			<geom type="mesh" name="r_leg" mesh="r_leg"/>
			<body pos="0 0 0" euler="0 0 0">
				<joint name="hip_joint" type="hinge" axis="1 0 0"/>
				<geom type="mesh" name="l_leg" mesh="l_leg"/>
			</body>
		</body>

	</worldbody>

	<actuator>
		<position joint="hip_joint"/>
	</actuator>
</mujoco>
